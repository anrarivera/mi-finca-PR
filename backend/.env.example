# Mi Finca PR — backend environment
# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mifinca?schema=public"

# JWT secrets — use long random strings (e.g. `openssl rand -hex 32`)
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string"

# Optional (defaults shown)
PORT=3001
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"
